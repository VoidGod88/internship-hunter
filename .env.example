# ── Email Settings (for sending applications) ──
EMAIL=
EMAIL_PASSWORD=
# For Gmail: use App Password (not your login password)
# Generate at: https://myaccount.google.com/apppasswords

# ── LLM Settings (for CV matching & cover letter generation) ──
LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com
# DeepSeek: https://api.deepseek.com
# OpenRouter: https://openrouter.ai/api/v1
# OpenAI: https://api.openai.com/v1
LLM_MODEL=deepseek-chat
# deepseek-chat (fast, cheap) / deepseek-reasoner (strong reasoning)
