# ─────────────────────────────────────────────
# .env — Credentials (fill in via UI or edit here)
# All settings editable in the ⚙️ Config tab
# ─────────────────────────────────────────────

# ── Email (Gmail SMTP) ──
EMAIL=
EMAIL_PASSWORD=

# ── LLM Provider (deepseek / openai / custom) ──
LLM_PROVIDER=deepseek
LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat

# ── PolyU Jobboard Credentials (optional) ──
POLYU_NET_ID=
POLYU_PASSWORD=
